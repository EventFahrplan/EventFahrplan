    <!-- Category Engelsystem -->
    <string name="preference_summary_engelsystem_json_export_url"><![CDATA[Per vedere i tuoi impegni inserisci l\'URL <u>personale</u> qui.<br/><br/>
        1. Accedi al tuo account <xliff:g example="Engelsystem" id="engelsystemAlias">%s</xliff:g>.<br/>
        2. Copia l\'URL dietro al pulsante <u>JSON Export</u> nella pagina del tuo profilo.<br/>
        3. Incolla l\'URL qui.<br/><br/>
        Gli impegni prima e dopo i giorni di conferenza principali <u>non</u> vengono visualizzati.]]></string>
